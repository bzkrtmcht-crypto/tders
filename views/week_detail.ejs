<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>HAFTA <%= week.week_number %> - Detay</title>
  <link rel="stylesheet" href="/css/style.css">
  <style>
    .hours-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(500px, 1fr));
      gap: 20px;
      margin: 30px 0;
    }

    .hour-box {
      border: 2px solid #e74c3c;
      border-radius: 8px;
      padding: 20px;
      background: linear-gradient(135deg, #fff9f5 0%, #ffe8dc 100%);
      box-shadow: 0 4px 6px rgba(0,0,0,0.1);
      transition: all 0.3s ease;
    }

    .hour-box:hover {
      box-shadow: 0 8px 12px rgba(0,0,0,0.15);
      transform: translateY(-2px);
    }

    .hour-number {
      font-size: 24px;
      font-weight: bold;
      color: #e74c3c;
      margin-bottom: 10px;
    }

    .hour-box h3 {
      color: #c0392b;
      margin: 10px 0;
      font-size: 18px;
    }

    .hour-field {
      margin: 15px 0;
      padding: 10px;
      background: white;
      border-left: 4px solid #e74c3c;
      border-radius: 4px;
    }

    .hour-field label {
      font-weight: bold;
      color: #2c3e50;
      display: block;
      margin-bottom: 5px;
      font-size: 12px;
      text-transform: uppercase;
    }

    .hour-field textarea {
      width: 100%;
      min-height: 80px;
      padding: 8px;
      border: 1px solid #bdc3c7;
      border-radius: 4px;
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      font-size: 13px;
    }

    .hour-field p {
      margin: 5px 0;
      line-height: 1.6;
      color: #555;
      white-space: pre-wrap;
    }

    .hour-actions {
      margin-top: 15px;
      display: flex;
      gap: 10px;
    }

    .btn-small {
      padding: 6px 12px;
      font-size: 12px;
    }

    .edit-mode .hour-field textarea {
      display: block;
    }

    .edit-mode .hour-field p {
      display: none;
    }

    .view-mode .hour-field textarea {
      display: none;
    }

    .view-mode .hour-field p {
      display: block;
    }

    .week-header {
      background: linear-gradient(135deg, #e74c3c 0%, #c0392b 100%);
      color: white;
      padding: 30px;
      border-radius: 8px;
      margin-bottom: 30px;
    }

    .week-header h1 {
      margin: 0;
      font-size: 28px;
    }

    .week-header .subtitle {
      margin-top: 10px;
      font-size: 16px;
      opacity: 0.9;
    }

    .back-link {
      color: white;
      text-decoration: none;
      font-size: 14px;
      margin-top: 15px;
      display: inline-block;
    }

    .back-link:hover {
      text-decoration: underline;
    }

    .container {
      max-width: 1400px;
    }
  </style>
</head>
<body>
  <div class="container">
    <div class="week-header">
      <a href="/" class="back-link">← ANA SAYFA</a>
      <h1>HAFTA <%= week.week_number %></h1>
      <p class="subtitle"><%= week.title %></p>
      <div style="margin-top: 20px;">
        <strong>Hedef:</strong> <%= week.goals %>
      </div>
    </div>

    <div style="margin-bottom: 20px; padding: 15px; background: #ecf0f1; border-radius: 4px;">
      <h3 style="margin-top: 0;">60 Dakika = 6 x 10 Dakika Bölümü</h3>
      <p>Aşağıdaki kutucuklarda her 10 dakikalık dersin detayları var. Düzenlemek için "Düzenle" butonuna tıkla, kaydettikten sonra "Görüntüle"ye tıkla.</p>
    </div>

    <div class="hours-grid">
      <% if (hours && hours.length > 0) { %>
        <% hours.forEach(hour => { %>
          <div class="hour-box view-mode" id="hour-<%= hour.id %>">
            <div class="hour-number">⏰ SAAT <%= hour.hour_number %}</div>

            <h3><%= hour.baslik %></h3>

            <div class="hour-field">
              <label>⏱️ SURE</label>
              <textarea name="sure" class="edit-textarea"><%= hour.sure %></textarea>
              <p><strong><%= hour.sure %></strong></p>
            </div>

            <div class="hour-field">
              <label>🎯 HEDEFLER</label>
              <textarea name="hedefler" class="edit-textarea"><%= hour.hedefler %></textarea>
              <p><%= hour.hedefler %></p>
            </div>

            <div class="hour-field">
              <label>📚 KONU BAŞLIKLARI</label>
              <textarea name="konu_baslikları" class="edit-textarea"><%= hour.konu_baslikları %></textarea>
              <p><%= hour.konu_baslikları %></p>
            </div>

            <div class="hour-field">
              <label>📝 NOTLAR & UYARILAR</label>
              <textarea name="notlar" class="edit-textarea"><%= hour.notlar %></textarea>
              <p><%= hour.notlar %></p>
            </div>

            <div class="hour-actions">
              <button class="btn btn-primary btn-small" onclick="editHour(<%= hour.id %>)">✏️ Düzenle</button>
              <button class="btn btn-success btn-small" onclick="saveHour(<%= hour.id %>, this)" style="display:none;">✔️ Kaydet</button>
              <button class="btn btn-secondary btn-small" onclick="cancelEdit(<%= hour.id %>)" style="display:none;">✕ İptal</button>
            </div>
          </div>
        <% }); %>
      <% } else { %>
        <div style="grid-column: 1/-1; padding: 20px; text-align: center; background: #ecf0f1; border-radius: 8px;">
          <p>Bu hafta için henüz saat eklenmedi.</p>
          <button class="btn btn-primary" onclick="addNewHour()">+ Yeni Saat Ekle</button>
        </div>
      <% } %>
    </div>
  </div>

  <script>
    function editHour(hourId) {
      const box = document.getElementById(`hour-${hourId}`);
      box.classList.remove('view-mode');
      box.classList.add('edit-mode');

      // Edit butonlarını gizle, Kaydet ve İptal butonlarını göster
      const buttons = box.querySelectorAll('button');
      buttons[0].style.display = 'none';   // Düzenle
      buttons[1].style.display = 'inline'; // Kaydet
      buttons[2].style.display = 'inline'; // İptal
    }

    function cancelEdit(hourId) {
      const box = document.getElementById(`hour-${hourId}`);
      box.classList.remove('edit-mode');
      box.classList.add('view-mode');

      // Butonları eski haline dön
      const buttons = box.querySelectorAll('button');
      buttons[0].style.display = 'inline';
      buttons[1].style.display = 'none';
      buttons[2].style.display = 'none';

      // Değişiklikleri geri al
      location.reload();
    }

    function saveHour(hourId, button) {
      const box = document.getElementById(`hour-${hourId}`);
      const textareas = box.querySelectorAll('textarea');

      const data = {
        baslik: box.querySelector('h3').textContent,
        sure: textareas[0].value,
        hedefler: textareas[1].value,
        konu_baslikları: textareas[2].value,
        notlar: textareas[3].value
      };

      fetch(`/api/hours/${hourId}`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
      })
        .then(res => res.json())
        .then(result => {
          if (result.success) {
            alert('Saat başarıyla güncellendi!');
            location.reload();
          }
        })
        .catch(err => alert('Hata: ' + err));
    }

    function addNewHour() {
      const weekId = '<%= week.id %>';
      const hourNumber = <% if (hours && hours.length > 0) { %><%= hours.length + 1 %><% } else { %>1<% } %>;

      const data = {
        week_id: weekId,
        hour_number: hourNumber,
        baslik: `Saat ${hourNumber}`,
        sure: '10 dakika',
        hedefler: 'Hedefleri yazınız',
        konu_baslikları: 'Konuları yazınız',
        notlar: 'Notları yazınız'
      };

      fetch('/api/hours', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
      })
        .then(res => res.json())
        .then(result => {
          if (result.success) {
            alert('Yeni saat eklendi!');
            location.reload();
          }
        })
        .catch(err => alert('Hata: ' + err));
    }
  </script>
</body>
</html>
