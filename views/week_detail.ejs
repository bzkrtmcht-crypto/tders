<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Hafta Detayı</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="container">
    <header>
      <h1>HAFTA <%= week.week_number %></h1>
      <a href="/" class="back-link">← Geri Dön</a>
    </header>

    <section class="edit-form-container">
      <h2><%= week.title %></h2>
      <p><strong>Hedef:</strong> <%= week.goals %></p>

      <div style="margin-top: 30px;">
        <h3>Zaman Bölümleri</h3>

        <% if (hours && hours.length > 0) { %>
          <% hours.forEach(function(hour) { %>
            <div style="background: white; border: 2px solid #e74c3c; border-radius: 8px; padding: 20px; margin-bottom: 15px;">
              <h4 style="color: #e74c3c; margin-bottom: 10px;">Bölüm <%= hour.hour_number %>: <%= hour.baslik %></h4>

              <div style="margin: 10px 0;">
                <strong>Süre:</strong> <%= hour.sure %>
              </div>

              <div style="margin: 10px 0;">
                <strong>Hedefler:</strong> <%= hour.hedefler %>
              </div>

              <div style="margin: 10px 0;">
                <strong>Konular:</strong> <%= hour.konu_baslikları %>
              </div>

              <div style="margin: 10px 0;">
                <strong>Notlar:</strong> <%= hour.notlar %>
              </div>

              <button onclick="editHour(<%= hour.id %>)" style="background: #e74c3c; color: white; padding: 8px 12px; border: none; border-radius: 4px; cursor: pointer; margin-top: 10px;">
                Düzenle
              </button>
            </div>
          <% }); %>
        <% } else { %>
          <p>Bu hafta için bölüm eklenmedi.</p>
        <% } %>
      </div>
    </section>
  </div>

  <script>
    function editHour(id) {
      alert('Bölüm düzenleme: ' + id);
    }
  </script>
</body>
</html>